        "code": "USER_ALREADY_EXIST",
        "message": "This user already exist"
    },
    "USER_NOT_FOUND": {
        "http": 404,
        "code": "USER_NOT_FOUND",
        "message": "This user is not found"
    },
    "LETTER_NOT_FOUND": {
        "http": 404,
        "code": "LETTER_NOT_FOUND",
        "messsage": "This letter is not found"
    },
    "LETTER_LOCKED": {
        "http": 401,
        "code": "LETTER_LOCKED",
        "message": "This letter is password protected, unlock to view the message."
    },
    "INVALID_FILETYPE": {
        "http": 415,
        "code": "INVALID_FILETYPE",
        "message": "Unsupported file type, only {media} is allowed."
    },
