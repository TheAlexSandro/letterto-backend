{
    "UNAUTHORIZED": {
        "http": 401,
        "code": "UNAUTHORIZED",
        "message": "Unauthorized"
    },
    "INVALID_PASSWORD": {
        "http": 401,
        "code": "INVALID_PASSWORD",
        "message": "Invalid password."
    },
    "BAD_REQUEST": {
        "http": 400,
        "code": "BAD_REQUEST",
        "message": "Something went wrong..."
    },
