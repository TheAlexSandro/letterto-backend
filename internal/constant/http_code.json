        "http": 404,
        "code": "OPTIONAL_PARAMETER_REQUIRED",
        "message": "Paramater {opt_param} is required when parameter {param} is used."
    },
    "TOO_MANY_FILES": {
        "http": 426,
        "code": "TOO_MANY_FILES",
        "message": "Only 1 file at the time is allowed."
    },
    "LENGTH_TOO_SHORT": {
        "http": 400,
